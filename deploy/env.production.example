# =============================================================================
# AV Pool — configuration de production
# Copier vers /opt/avpool/.env.production  (chmod 600, owner avpool)
# NE JAMAIS committer le fichier rempli (.env* est gitignore).
# =============================================================================

# Environnement (active les garde-fous : secret obligatoire, refus du mdp admin par defaut)
NODE_ENV=production

# Secret de signature des JWT de session.
# Generer une valeur unique :  openssl rand -base64 48
AUTH_SECRET=__REMPLACER_PAR_openssl_rand_base64_48__

# Base SQLite — chemin ABSOLU sur un disque persistant de la VM.
DATABASE_URL=file:/opt/avpool/data/avpool.db

# URL publique (utilisee pour les liens dans les emails de rappel de certification)
NEXTAUTH_URL=https://pool.spektalis.net

# Port / interface d'ecoute.
# 0.0.0.0 pour que Traefik (192.168.1.2) joigne l'app sur le LAN.
PORT=3000
HOSTNAME=0.0.0.0

# --- Compte admin initial (lu uniquement par le seed, au 1er deploiement) ------
ADMIN_EMAIL=admin@spektalis.net
ADMIN_NAME=Administrateur
# Generer :  openssl rand -base64 18 | tr -d '/+=' | cut -c1-20
ADMIN_PASSWORD=__REMPLACER_avant_le_seed__

# --- Coffre-fort de documents (optionnel) --------------------------------------
# Repertoire des fichiers uploades. Defaut : <cwd>/data/uploads (= /opt/avpool/data/uploads).
# UPLOAD_DIR=/opt/avpool/data/uploads

# --- Extraction IA depuis un PDF (optionnel) -----------------------------------
# Sans ces variables, l'extraction fonctionne par correspondance avec le referentiel.
# Avec un endpoint compatible OpenAI (Atlas, LM Studio...), l'IA ameliore l'extraction.
# AI_BASE_URL=http://192.168.1.249:1234/v1
# AI_API_KEY=
# AI_MODEL=local-model
