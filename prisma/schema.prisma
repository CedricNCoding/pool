generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Tenant = client/entreprise abonne. Cloisonnement fort : toute donnee metier
// porte un tenantId et toute requete est filtree par le tenant de la session.
model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  status    String   @default("active") // active | suspended
  createdAt DateTime @default(now()) @map("created_at")

  users           User[]
  companies       Company[]
  agencies        Agency[]
  technicians     Technician[]
  skillCategories SkillCategory[]
  skills          Skill[]
  certifications  Certification[]
  projects        Project[]
  trainingModules TrainingModule[]
  trainingPaths   TrainingPath[]
  assignments     TrainingAssignment[]
  tags            Tag[]
  objectives      SkillObjective[]
  apiKeys         ApiKey[]
  auditLogs       AuditLog[]
  documents       Document[]
  events          TechnicianEvent[]
  assistanceRequests AssistanceRequest[]
  webhooks        Webhook[]
  trainingAssignmentEvents TrainingAssignmentEvent[]
  trainingSessions         TrainingSession[]
  trainingSessionDocuments TrainingSessionDocument[]
  trainingSessionEvents    TrainingSessionEvent[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         String   @default("manager") // superadmin | admin | manager
  tenantId     String?  @map("tenant_id")
  companyId    String?  @map("company_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant?    @relation(fields: [tenantId], references: [id])
  company   Company?   @relation(fields: [companyId], references: [id])
  auditLogs AuditLog[]

  @@map("users")
}

model Company {
  id         String   @id @default(uuid())
  name       String
  siret      String?
  address    String?
  city       String?
  country    String   @default("France")
  postalCode String?  @map("postal_code")
  lat        Float?
  lng        Float?
  phone      String?
  email      String?
  logoUrl    String?  @map("logo_url")
  color      String   @default("#E89B2C")
  tenantId   String?  @map("tenant_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  agencies    Agency[]
  technicians Technician[]
  users       User[]
  apiKeys     ApiKey[]
  projects    Project[]
  assistanceRequests AssistanceRequest[] @relation("AssistanceRequester")

  @@index([tenantId])
  @@map("companies")
}

model Agency {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  name       String
  address    String?
  city       String?
  country    String   @default("France")
  postalCode String?  @map("postal_code")
  lat        Float?
  lng        Float?
  phone      String?
  tenantId   String?  @map("tenant_id")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  technicians Technician[]

  @@index([tenantId])
  @@map("agencies")
}

model Technician {
  id                    String    @id @default(uuid())
  firstName             String    @map("first_name")
  lastName              String    @map("last_name")
  email                 String
  phone                 String?
  companyId             String    @map("company_id")
  agencyId              String?   @map("agency_id")
  tenantId              String?   @map("tenant_id")
  service               String    @default("tech")
  contractType          String    @map("contract_type") @default("CDI")
  contractStart         DateTime? @map("contract_start")
  contractEnd           DateTime? @map("contract_end")
  interventionCenterLat Float?    @map("intervention_center_lat")
  interventionCenterLng Float?    @map("intervention_center_lng")
  interventionRadiusKm  Int       @default(50) @map("intervention_radius_km")
  isActive              Boolean   @default(true) @map("is_active")
  availabilityStatus    String    @default("disponible") @map("availability_status") // disponible | en_mission | indisponible
  availableUntil        DateTime? @map("available_until")
  departureDate         DateTime? @map("departure_date")
  scheduledDeletionDate DateTime? @map("scheduled_deletion_date")
  notes                 String?
  // Visite médicale du travail : date de la dernière + périodicité (mois) ->
  // prochaine échéance = date + périodicité. Défaut 24 mois (suivi renforcé AV).
  medicalVisitDate              DateTime? @map("medical_visit_date")
  medicalVisitPeriodicityMonths Int       @default(24) @map("medical_visit_periodicity_months")
  // Permis de conduire détenus (catégories séparées par des virgules : "B,C,CE")
  drivingLicenses       String?   @map("driving_licenses")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  tenant         Tenant?                   @relation(fields: [tenantId], references: [id])
  company        Company                   @relation(fields: [companyId], references: [id])
  agency         Agency?                   @relation(fields: [agencyId], references: [id])
  skills              TechnicianSkill[]
  certifications      TechnicianCertification[]
  skillHistory        TechnicianSkillHistory[]
  projects            Project[]
  trainingAssignments TrainingAssignment[]
  documents           Document[]
  tags                Tag[]
  events              TechnicianEvent[]
  assistanceRequests  AssistanceRequest[] @relation("AssistanceTech")

  @@index([tenantId])
  @@map("technicians")
}

model SkillCategory {
  id       String  @id @default(uuid())
  name     String
  color    String  @default("#6366F1")
  icon     String  @default("Wrench")
  order    Int     @default(0)
  tenantId String? @map("tenant_id")

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  skills Skill[]

  @@unique([tenantId, name])
  @@map("skill_categories")
}

model Skill {
  id          String  @id @default(uuid())
  name        String
  categoryId  String  @map("category_id")
  description String?
  order       Int     @default(0)
  tenantId    String? @map("tenant_id")

  tenant          Tenant?           @relation(fields: [tenantId], references: [id])
  category        SkillCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  technicians     TechnicianSkill[]
  history         TechnicianSkillHistory[]
  trainingModules TrainingModule[]
  objectives      SkillObjective[]

  @@unique([name, categoryId])
  @@index([tenantId])
  @@map("skills")
}

// Objectif de montee en competences : atteindre targetPercent % de techniciens
// actifs a un niveau >= minLevel sur une competence, avant une echeance.
model SkillObjective {
  id            String    @id @default(uuid())
  label         String
  skillId       String?   @map("skill_id")
  tenantId      String?   @map("tenant_id")
  minLevel      Int       @default(3) @map("min_level")
  targetPercent Int       @default(80) @map("target_percent")
  deadline      DateTime?
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  skill  Skill?  @relation(fields: [skillId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("skill_objectives")
}

model TechnicianSkill {
  id           String   @id @default(uuid())
  technicianId String   @map("technician_id")
  skillId      String   @map("skill_id")
  level        Int      @default(1)
  updatedAt    DateTime @updatedAt @map("updated_at")

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([technicianId, skillId])
  @@map("technician_skills")
}

// Historique des niveaux de competence : un enregistrement par changement,
// pour suivre l'evolution d'un technicien dans le temps.
model TechnicianSkillHistory {
  id           String   @id @default(uuid())
  technicianId String   @map("technician_id")
  skillId      String   @map("skill_id")
  level        Int
  userId       String?  @map("user_id")
  recordedAt   DateTime @default(now()) @map("recorded_at")

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([technicianId])
  @@map("technician_skill_history")
}

model Certification {
  id             String @id @default(uuid())
  name           String
  issuer         String
  description    String?
  validityMonths Int?   @map("validity_months")
  category       String @default("general")
  color          String @default("#10B981")
  level          String @default("standard")
  order          Int    @default(0)
  tenantId       String? @map("tenant_id")

  tenant      Tenant?                  @relation(fields: [tenantId], references: [id])
  technicians TechnicianCertification[]

  @@unique([tenantId, name, issuer])
  @@map("certifications")
}

model TechnicianCertification {
  id                String    @id @default(uuid())
  technicianId      String    @map("technician_id")
  certificationId   String    @map("certification_id")
  obtainedDate      DateTime  @map("obtained_date")
  expiryDate        DateTime? @map("expiry_date")
  certificateNumber String?   @map("certificate_number")
  status            String    @default("active")
  documentId        String?   @map("document_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  technician    Technician    @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  document      Document?     @relation("CertDoc", fields: [documentId], references: [id], onDelete: SetNull)

  @@unique([technicianId, certificationId])
  @@map("technician_certifications")
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyHash     String    @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  companyId   String?   @map("company_id")
  tenantId    String?   @map("tenant_id")
  permissions String    @default("read")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant  Tenant?  @relation(fields: [tenantId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@index([tenantId])
  @@map("api_keys")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  tenantId   String?  @map("tenant_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  details    String?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("audit_logs")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

// Journal de suivi : evenements dates par technicien (entretien, incident, evaluation...)
model TechnicianEvent {
  id           String   @id @default(uuid())
  technicianId String   @map("technician_id")
  tenantId     String?  @map("tenant_id")
  type         String   @default("note") // entretien | incident | evaluation | note | autre
  title        String
  body         String?
  date         DateTime
  createdById  String?  @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant?    @relation(fields: [tenantId], references: [id])
  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId])
  @@index([tenantId])
  @@map("technician_events")
}

// Etiquettes / attributs libres (vehicule, habilite hauteur, anglais, permis...)
model Tag {
  id          String       @id @default(uuid())
  name        String
  color       String       @default("#64748B")
  tenantId    String?      @map("tenant_id")
  createdAt   DateTime     @default(now()) @map("created_at")

  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  technicians Technician[]

  @@unique([tenantId, name])
  @@map("tags")
}

// Coffre-fort : documents rattaches a un technicien (contrat, identite,
// visite medicale, habilitation, certificat...). Fichier stocke sur disque.
model Document {
  id           String    @id @default(uuid())
  technicianId String    @map("technician_id")
  category     String    @default("autre") // contrat | identite | medical | habilitation | certificat | diplome | autre
  title        String
  fileName     String    @map("file_name")
  originalName String    @map("original_name")
  mimeType     String    @map("mime_type")
  size         Int
  expiryDate   DateTime? @map("expiry_date")
  uploadedById String?   @map("uploaded_by_id")
  tenantId     String?   @map("tenant_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant     Tenant?    @relation(fields: [tenantId], references: [id])
  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  certLinks  TechnicianCertification[] @relation("CertDoc")

  @@index([technicianId])
  @@index([tenantId])
  @@map("documents")
}

// Projet / Equipe : un titre, une description libre, et une liste de techniciens.
// Cloisonne par entreprise (companyId = entreprise du createur ; null = admin).
model Project {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("actif") // actif | termine | archive
  companyId   String?  @map("company_id")
  tenantId    String?  @map("tenant_id")
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  company     Company?     @relation(fields: [companyId], references: [id])
  technicians Technician[]

  @@index([tenantId])
  @@map("projects")
}

// ----- Formation -----------------------------------------------------------

// Modele de formation : developpe une ou plusieurs competences.
model TrainingModule {
  id            String   @id @default(uuid())
  title         String
  description   String?
  durationHours Int?     @map("duration_hours")
  cost          Int      @default(0) @map("cost_eur")
  tenantId      String?  @map("tenant_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant       Tenant?              @relation(fields: [tenantId], references: [id])
  targetSkills Skill[]
  assignments  TrainingAssignment[]
  pathModules  TrainingPathModule[]
  sessions     TrainingSession[]

  @@index([tenantId])
  @@map("training_modules")
}

// Parcours : suite ordonnee de modules.
model TrainingPath {
  id          String   @id @default(uuid())
  title       String
  description String?
  tenantId    String?  @map("tenant_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant?              @relation(fields: [tenantId], references: [id])
  modules     TrainingPathModule[]
  assignments TrainingAssignment[]
  sessions    TrainingSession[]

  @@index([tenantId])
  @@map("training_paths")
}

model TrainingPathModule {
  id       String @id @default(uuid())
  pathId   String @map("path_id")
  moduleId String @map("module_id")
  order    Int    @default(0)

  path   TrainingPath   @relation(fields: [pathId], references: [id], onDelete: Cascade)
  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("training_path_modules")
}

// Affectation d'un technicien a un module ou parcours, avec validation.
model TrainingAssignment {
  id            String    @id @default(uuid())
  technicianId  String    @map("technician_id")
  moduleId      String?   @map("module_id")
  pathId        String?   @map("path_id")
  sessionId     String?   @map("session_id")
  status        String    @default("propose") // propose | en_cours | valide | annule
  note          String?
  // Financement par participant (choix utilisateur) : coût + organisme + dossier.
  cost          Float?    @map("cost_eur")
  fundingSource String?   @map("funding_source") // opco | cpf | interne | client | autre
  fundingRef    String?   @map("funding_ref")
  assignedById  String?   @map("assigned_by_id")
  validatedById String?   @map("validated_by_id")
  validatedAt   DateTime? @map("validated_at")
  tenantId      String?   @map("tenant_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant     Tenant?          @relation(fields: [tenantId], references: [id])
  technician Technician       @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  module     TrainingModule?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  path       TrainingPath?    @relation(fields: [pathId], references: [id], onDelete: Cascade)
  session    TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  history    TrainingAssignmentEvent[]

  @@index([tenantId])
  @@index([sessionId])
  @@map("training_assignments")
}

// Fiche de session de formation : regroupe les participants (TrainingAssignment),
// le contenu (module/parcours), les documents, l'historique. Le financement est
// porté par chaque participant (cost/fundingSource/fundingRef sur l'affectation).
model TrainingSession {
  id        String    @id @default(uuid())
  tenantId  String?   @map("tenant_id")
  moduleId  String?   @map("module_id") // contenu / programme
  pathId    String?   @map("path_id")
  title     String
  status    String    @default("planifiee") // planifiee | en_cours | terminee | annulee
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  location  String?
  trainer   String? // formateur / organisme
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant       Tenant?                @relation(fields: [tenantId], references: [id])
  module       TrainingModule?        @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  path         TrainingPath?          @relation(fields: [pathId], references: [id], onDelete: SetNull)
  participants TrainingAssignment[]
  documents    TrainingSessionDocument[]
  history      TrainingSessionEvent[]

  @@index([tenantId])
  @@map("training_sessions")
}

// Document attaché à une session (convention, devis, convocation, attestation
// collective…). Stocké sous UPLOAD_DIR/sessions/{sessionId}/{fileName}.
model TrainingSessionDocument {
  id           String   @id @default(uuid())
  sessionId    String   @map("session_id")
  tenantId     String?  @map("tenant_id")
  category     String   @default("autre")
  title        String
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tenant  Tenant?         @relation(fields: [tenantId], references: [id])

  @@index([sessionId])
  @@index([tenantId])
  @@map("training_session_documents")
}

// Historique du cycle de vie d'une session (créée, planifiée, démarrée,
// terminée, annulée, participant/document ajouté…). actorName dénormalisé.
model TrainingSessionEvent {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  tenantId  String?  @map("tenant_id")
  kind      String   @default("status") // status | participant | document | funding | info
  label     String
  actorId   String?  @map("actor_id")
  actorName String?  @map("actor_name")
  createdAt DateTime @default(now()) @map("created_at")

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tenant  Tenant?         @relation(fields: [tenantId], references: [id])

  @@index([sessionId])
  @@index([tenantId])
  @@map("training_session_events")
}

// Historique du cycle de vie d'une affectation : chaque transition de statut
// (proposé -> en cours -> validé / annulé) est tracée avec l'auteur et la date.
// actorName est dénormalisé (instantané) pour rester lisible même si l'auteur
// est renommé ou supprimé.
model TrainingAssignmentEvent {
  id           String   @id @default(uuid())
  assignmentId String   @map("assignment_id")
  status       String // propose | en_cours | valide | annule
  note         String?
  actorId      String?  @map("actor_id")
  actorName    String?  @map("actor_name")
  tenantId     String?  @map("tenant_id")
  createdAt    DateTime @default(now()) @map("created_at")

  assignment TrainingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  tenant     Tenant?            @relation(fields: [tenantId], references: [id])

  @@index([assignmentId])
  @@index([tenantId])
  @@map("training_assignment_events")
}

// Demande de renfort : un gestionnaire sollicite un technicien d'une AUTRE
// société du tenant (vu anonymisé). Seul l'admin du tenant arbitre.
model AssistanceRequest {
  id                 String    @id @default(uuid())
  tenantId           String?   @map("tenant_id")
  technicianId       String    @map("technician_id")
  requesterUserId    String?   @map("requester_user_id")
  requesterCompanyId String?   @map("requester_company_id")
  message            String
  status             String    @default("pending") // pending | accepted | declined
  adminNote          String?   @map("admin_note")
  resolvedById       String?   @map("resolved_by_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  resolvedAt         DateTime? @map("resolved_at")

  tenant           Tenant?    @relation(fields: [tenantId], references: [id])
  technician       Technician @relation("AssistanceTech", fields: [technicianId], references: [id], onDelete: Cascade)
  requesterCompany Company?   @relation("AssistanceRequester", fields: [requesterCompanyId], references: [id])

  @@index([tenantId])
  @@index([technicianId])
  @@map("assistance_requests")
}

// Webhook sortant : Praxis POST le payload d'un événement vers une URL tierce,
// signé en HMAC-SHA256 (en-tête X-Praxis-Signature) avec `secret`. Cloisonné
// par tenant. `events` = "all" ou liste CSV (ex. "assistance.created").
model Webhook {
  id          String    @id @default(uuid())
  tenantId    String?   @map("tenant_id")
  url         String
  events      String    @default("all")
  secret      String
  isActive    Boolean   @default(true) @map("is_active")
  lastStatus  Int?      @map("last_status")
  lastError   String?   @map("last_error")
  lastFiredAt DateTime? @map("last_fired_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("webhooks")
}
