generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Tenant = client/entreprise abonne. Cloisonnement fort : toute donnee metier
// porte un tenantId et toute requete est filtree par le tenant de la session.
model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  status    String   @default("active") // active | suspended
  createdAt DateTime @default(now()) @map("created_at")

  users           User[]
  companies       Company[]
  agencies        Agency[]
  technicians     Technician[]
  skillCategories SkillCategory[]
  skills          Skill[]
  certifications  Certification[]
  projects        Project[]
  trainingModules TrainingModule[]
  trainingPaths   TrainingPath[]
  assignments     TrainingAssignment[]
  tags            Tag[]
  objectives      SkillObjective[]
  apiKeys         ApiKey[]
  auditLogs       AuditLog[]
  documents       Document[]
  events          TechnicianEvent[]
  assistanceRequests AssistanceRequest[]
  webhooks        Webhook[]
  trainingAssignmentEvents TrainingAssignmentEvent[]
  trainingSessions         TrainingSession[]
  trainingSessionDocuments TrainingSessionDocument[]
  trainingSessionEvents    TrainingSessionEvent[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         String   @default("manager") // superadmin | admin | manager
  tenantId     String?  @map("tenant_id")
  companyId    String?  @map("company_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant?    @relation(fields: [tenantId], references: [id])
  company   Company?   @relation(fields: [companyId], references: [id])
  auditLogs AuditLog[]

  @@map("users")
}

model Company {
  id         String   @id @default(uuid())
  name       String
  siret      String?
  address    String?
  city       String?
  country    String   @default("France")
  postalCode String?  @map("postal_code")
  lat        Float?
  lng        Float?
  phone      String?
  email      String?
  logoUrl    String?  @map("logo_url")
  color      String   @default("#E89B2C")
  tenantId   String?  @map("tenant_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  agencies    Agency[]
  technicians Technician[]
  users       User[]
  apiKeys     ApiKey[]
  projects    Project[]
  assistanceRequests AssistanceRequest[] @relation("AssistanceRequester")

  @@index([tenantId])
  @@map("companies")
}

model Agency {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  name       String
  address    String?
  city       String?
  country    String   @default("France")
  postalCode String?  @map("postal_code")
  lat        Float?
  lng        Float?
  phone      String?
  tenantId   String?  @map("tenant_id")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  technicians Technician[]

  @@index([tenantId])
  @@map("agencies")
}

model Technician {
  id                    String    @id @default(uuid())
  firstName             String    @map("first_name")
  lastName              String    @map("last_name")
  email                 String
  phone                 String?
  companyId             String    @map("company_id")
  agencyId              String?   @map("agency_id")
  tenantId              String?   @map("tenant_id")
  service               String    @default("tech")
  contractType          String    @map("contract_type") @default("CDI")
  contractStart         DateTime? @map("contract_start")
  contractEnd           DateTime? @map("contract_end")
  interventionCenterLat Float?    @map("intervention_center_lat")
  interventionCenterLng Float?    @map("intervention_center_lng")
  interventionRadiusKm  Int       @default(50) @map("intervention_radius_km")
  isActive              Boolean   @default(true) @map("is_active")
  availabilityStatus    String    @default("disponible") @map("availability_status") // disponible | en_mission | indisponible
  availableUntil        DateTime? @map("available_until")
  departureDate         DateTime? @map("departure_date")
  scheduledDeletionDate DateTime? @map("scheduled_deletion_date")
  notes                 String?
  // Visite médicale du travail : date de la dernière + périodicité (mois) ->
  // prochaine échéance = date + périodicité. Défaut 24 mois (suivi renforcé AV).
  medicalVisitDate              DateTime? @map("medical_visit_date")
  medicalVisitPeriodicityMonths Int       @default(24) @map("medical_visit_periodicity_months")
  // Permis de conduire détenus (catégories séparées par des virgules : "B,C,CE")
  drivingLicenses       String?   @map("driving_licenses")
  // Aptitude médicale (médecin du travail) : apte | apte_restrictions | inapte_temp | inapte.
  // Restrictions = CSV de clés (hauteur,charges,conduite,vision,nuit). Secret médical : pas de diagnostic.
  medicalAptitude       String?   @map("medical_aptitude")
  medicalRestrictions   String?   @map("medical_restrictions")
  medicalRestrictionUntil DateTime? @map("medical_restriction_until")
  // Rapprochement Odoo (Béta) : id de l'utilisateur Odoo (res.users) correspondant.
  odooUserId            Int?      @map("odoo_user_id")
  odooUserName          String?   @map("odoo_user_name")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  tenant         Tenant?                   @relation(fields: [tenantId], references: [id])
  company        Company                   @relation(fields: [companyId], references: [id])
  agency         Agency?                   @relation(fields: [agencyId], references: [id])
  skills              TechnicianSkill[]
  certifications      TechnicianCertification[]
  skillHistory        TechnicianSkillHistory[]
  projects            Project[]
  trainingAssignments TrainingAssignment[]
  documents           Document[]
  tags                Tag[]
  events              TechnicianEvent[]
  assistanceRequests  AssistanceRequest[] @relation("AssistanceTech")
  bookings              Booking[]
  absences              Absence[]
  equipmentAssignments  EquipmentAssignment[]
  safetyAcks            SafetyNoticeAck[]
  selfAssessments       SkillSelfAssessment[]
  interviews            Interview[]

  @@index([tenantId])
  @@map("technicians")
}

model SkillCategory {
  id       String  @id @default(uuid())
  name     String
  color    String  @default("#6366F1")
  icon     String  @default("Wrench")
  order    Int     @default(0)
  tenantId String? @map("tenant_id")

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  skills Skill[]

  @@unique([tenantId, name])
  @@map("skill_categories")
}

model Skill {
  id          String  @id @default(uuid())
  name        String
  categoryId  String  @map("category_id")
  description String?
  order       Int     @default(0)
  tenantId    String? @map("tenant_id")

  tenant          Tenant?           @relation(fields: [tenantId], references: [id])
  category        SkillCategory     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  technicians     TechnicianSkill[]
  history         TechnicianSkillHistory[]
  trainingModules TrainingModule[]
  objectives      SkillObjective[]

  @@unique([name, categoryId])
  @@index([tenantId])
  @@map("skills")
}

// Objectif de montee en competences : atteindre targetPercent % de techniciens
// actifs a un niveau >= minLevel sur une competence, avant une echeance.
model SkillObjective {
  id            String    @id @default(uuid())
  label         String
  skillId       String?   @map("skill_id")
  tenantId      String?   @map("tenant_id")
  minLevel      Int       @default(3) @map("min_level")
  targetPercent Int       @default(80) @map("target_percent")
  deadline      DateTime?
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  skill  Skill?  @relation(fields: [skillId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@map("skill_objectives")
}

model TechnicianSkill {
  id           String   @id @default(uuid())
  technicianId String   @map("technician_id")
  skillId      String   @map("skill_id")
  level        Int      @default(1)
  updatedAt    DateTime @updatedAt @map("updated_at")

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([technicianId, skillId])
  @@map("technician_skills")
}

// Historique des niveaux de competence : un enregistrement par changement,
// pour suivre l'evolution d'un technicien dans le temps.
model TechnicianSkillHistory {
  id           String   @id @default(uuid())
  technicianId String   @map("technician_id")
  skillId      String   @map("skill_id")
  level        Int
  userId       String?  @map("user_id")
  recordedAt   DateTime @default(now()) @map("recorded_at")

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([technicianId])
  @@map("technician_skill_history")
}

model Certification {
  id             String @id @default(uuid())
  name           String
  issuer         String
  description    String?
  validityMonths Int?   @map("validity_months")
  category       String @default("general")
  color          String @default("#10B981")
  level          String @default("standard")
  order          Int    @default(0)
  tenantId       String? @map("tenant_id")

  tenant      Tenant?                  @relation(fields: [tenantId], references: [id])
  technicians TechnicianCertification[]
  requiredByProjects Project[] @relation("MissionRequiredCerts")

  @@unique([tenantId, name, issuer])
  @@map("certifications")
}

model TechnicianCertification {
  id                String    @id @default(uuid())
  technicianId      String    @map("technician_id")
  certificationId   String    @map("certification_id")
  obtainedDate      DateTime  @map("obtained_date")
  expiryDate        DateTime? @map("expiry_date")
  certificateNumber String?   @map("certificate_number")
  status            String    @default("active")
  documentId        String?   @map("document_id")
  // Workflow de renouvellement : ok | a_planifier | convoque | realise.
  renewalStatus     String    @default("ok") @map("renewal_status")
  renewalDate       DateTime? @map("renewal_date")
  renewalOrganism   String?   @map("renewal_organism")
  createdAt         DateTime  @default(now()) @map("created_at")

  technician    Technician    @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  certification Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  document      Document?     @relation("CertDoc", fields: [documentId], references: [id], onDelete: SetNull)

  @@unique([technicianId, certificationId])
  @@map("technician_certifications")
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyHash     String    @map("key_hash")
  keyPrefix   String    @map("key_prefix")
  companyId   String?   @map("company_id")
  tenantId    String?   @map("tenant_id")
  permissions String    @default("read")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant  Tenant?  @relation(fields: [tenantId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@index([tenantId])
  @@map("api_keys")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  tenantId   String?  @map("tenant_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  details    String?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User?   @relation(fields: [userId], references: [id])
  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("audit_logs")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

// Journal de suivi : evenements dates par technicien (entretien, incident, evaluation...)
model TechnicianEvent {
  id           String   @id @default(uuid())
  technicianId String   @map("technician_id")
  tenantId     String?  @map("tenant_id")
  type         String   @default("note") // entretien | incident | evaluation | note | autre
  title        String
  body         String?
  date         DateTime
  createdById  String?  @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant?    @relation(fields: [tenantId], references: [id])
  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId])
  @@index([tenantId])
  @@map("technician_events")
}

// Etiquettes / attributs libres (vehicule, habilite hauteur, anglais, permis...)
model Tag {
  id          String       @id @default(uuid())
  name        String
  color       String       @default("#64748B")
  tenantId    String?      @map("tenant_id")
  createdAt   DateTime     @default(now()) @map("created_at")

  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  technicians Technician[]

  @@unique([tenantId, name])
  @@map("tags")
}

// Coffre-fort : documents rattaches a un technicien (contrat, identite,
// visite medicale, habilitation, certificat...). Fichier stocke sur disque.
model Document {
  id           String    @id @default(uuid())
  technicianId String    @map("technician_id")
  category     String    @default("autre") // contrat | identite | medical | habilitation | certificat | diplome | autre
  title        String
  fileName     String    @map("file_name")
  originalName String    @map("original_name")
  mimeType     String    @map("mime_type")
  size         Int
  expiryDate   DateTime? @map("expiry_date")
  uploadedById String?   @map("uploaded_by_id")
  tenantId     String?   @map("tenant_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  tenant     Tenant?    @relation(fields: [tenantId], references: [id])
  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  certLinks  TechnicianCertification[] @relation("CertDoc")

  @@index([technicianId])
  @@index([tenantId])
  @@map("documents")
}

// Projet / Equipe : un titre, une description libre, et une liste de techniciens.
// Cloisonne par entreprise (companyId = entreprise du createur ; null = admin).
model Project {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("actif") // actif | termine | archive
  companyId   String?  @map("company_id")
  tenantId    String?  @map("tenant_id")
  createdById String?  @map("created_by_id")
  // Planification : dates et lieu de la mission.
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  // Dossier & client
  dossierNumber String? @map("dossier_number")
  clientName  String?   @map("client_name")
  clientContact String? @map("client_contact")
  clientPhone String?   @map("client_phone")
  clientEmail String?   @map("client_email")
  site        String?
  address     String?
  lat         Float?
  lng         Float?
  // Exigences de la mission : EPI requis (catégories CSV) + habilitations + formations (M2M).
  requiredEpi String?   @map("required_epi")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  company     Company?     @relation(fields: [companyId], references: [id])
  technicians Technician[]
  bookings        Booking[]
  requiredCertifications Certification[] @relation("MissionRequiredCerts")
  requiredTrainingModules TrainingModule[] @relation("MissionRequiredTraining")

  @@index([tenantId])
  @@map("projects")
}

// ----- Formation -----------------------------------------------------------

// Modele de formation : developpe une ou plusieurs competences.
model TrainingModule {
  id            String   @id @default(uuid())
  title         String
  description   String?
  durationHours Int?     @map("duration_hours")
  cost          Int      @default(0) @map("cost_eur")
  tenantId      String?  @map("tenant_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant       Tenant?              @relation(fields: [tenantId], references: [id])
  targetSkills Skill[]
  assignments  TrainingAssignment[]
  pathModules  TrainingPathModule[]
  sessions     TrainingSession[]
  requiredByProjects Project[] @relation("MissionRequiredTraining")

  @@index([tenantId])
  @@map("training_modules")
}

// Parcours : suite ordonnee de modules.
model TrainingPath {
  id          String   @id @default(uuid())
  title       String
  description String?
  tenantId    String?  @map("tenant_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant?              @relation(fields: [tenantId], references: [id])
  modules     TrainingPathModule[]
  assignments TrainingAssignment[]
  sessions    TrainingSession[]

  @@index([tenantId])
  @@map("training_paths")
}

model TrainingPathModule {
  id       String @id @default(uuid())
  pathId   String @map("path_id")
  moduleId String @map("module_id")
  order    Int    @default(0)

  path   TrainingPath   @relation(fields: [pathId], references: [id], onDelete: Cascade)
  module TrainingModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("training_path_modules")
}

// Affectation d'un technicien a un module ou parcours, avec validation.
model TrainingAssignment {
  id            String    @id @default(uuid())
  technicianId  String    @map("technician_id")
  moduleId      String?   @map("module_id")
  pathId        String?   @map("path_id")
  sessionId     String?   @map("session_id")
  status        String    @default("propose") // propose | en_cours | valide | annule
  note          String?
  // Financement par participant (choix utilisateur) : coût + organisme + dossier.
  cost          Float?    @map("cost_eur")
  fundingSource String?   @map("funding_source") // opco | cpf | interne | client | autre
  fundingRef    String?   @map("funding_ref")
  assignedById  String?   @map("assigned_by_id")
  validatedById String?   @map("validated_by_id")
  validatedAt   DateTime? @map("validated_at")
  tenantId      String?   @map("tenant_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant     Tenant?          @relation(fields: [tenantId], references: [id])
  technician Technician       @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  module     TrainingModule?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  path       TrainingPath?    @relation(fields: [pathId], references: [id], onDelete: Cascade)
  session    TrainingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  history    TrainingAssignmentEvent[]

  @@index([tenantId])
  @@index([sessionId])
  @@map("training_assignments")
}

// Fiche de session de formation : regroupe les participants (TrainingAssignment),
// le contenu (module/parcours), les documents, l'historique. Le financement est
// porté par chaque participant (cost/fundingSource/fundingRef sur l'affectation).
model TrainingSession {
  id        String    @id @default(uuid())
  tenantId  String?   @map("tenant_id")
  moduleId  String?   @map("module_id") // contenu / programme
  pathId    String?   @map("path_id")
  title     String
  status    String    @default("planifiee") // planifiee | en_cours | terminee | annulee
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  location  String?
  trainer   String? // formateur / organisme
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant       Tenant?                @relation(fields: [tenantId], references: [id])
  module       TrainingModule?        @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  path         TrainingPath?          @relation(fields: [pathId], references: [id], onDelete: SetNull)
  participants TrainingAssignment[]
  documents    TrainingSessionDocument[]
  history      TrainingSessionEvent[]

  @@index([tenantId])
  @@map("training_sessions")
}

// Document attaché à une session (convention, devis, convocation, attestation
// collective…). Stocké sous UPLOAD_DIR/sessions/{sessionId}/{fileName}.
model TrainingSessionDocument {
  id           String   @id @default(uuid())
  sessionId    String   @map("session_id")
  tenantId     String?  @map("tenant_id")
  category     String   @default("autre")
  title        String
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  uploadedById String?  @map("uploaded_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tenant  Tenant?         @relation(fields: [tenantId], references: [id])

  @@index([sessionId])
  @@index([tenantId])
  @@map("training_session_documents")
}

// Historique du cycle de vie d'une session (créée, planifiée, démarrée,
// terminée, annulée, participant/document ajouté…). actorName dénormalisé.
model TrainingSessionEvent {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  tenantId  String?  @map("tenant_id")
  kind      String   @default("status") // status | participant | document | funding | info
  label     String
  actorId   String?  @map("actor_id")
  actorName String?  @map("actor_name")
  createdAt DateTime @default(now()) @map("created_at")

  session TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tenant  Tenant?         @relation(fields: [tenantId], references: [id])

  @@index([sessionId])
  @@index([tenantId])
  @@map("training_session_events")
}

// ============================================================================
// PLANNING — affectations datées, absences
// ============================================================================

// Affectation datée d'un technicien à un projet/mission (créneau).
model Booking {
  id           String   @id @default(uuid())
  tenantId     String?  @map("tenant_id")
  projectId    String   @map("project_id")
  technicianId String   @map("technician_id")
  start        DateTime
  end          DateTime
  role         String?
  note         String?
  status       String   @default("pressenti") // pressenti | confirme | decline
  createdById  String?  @map("created_by_id")
  odooTaskId   Int?     @map("odoo_task_id") // id de la tâche Odoo synchronisée (Béta)
  createdAt    DateTime @default(now()) @map("created_at")

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([technicianId])
  @@index([projectId])
  @@map("bookings")
}

// Absence d'un technicien (congé, arrêt, RTT…). recurringWeekday : indispo
// hebdomadaire permanente (0=dim … 6=sam), sinon créneau daté start/end.
model Absence {
  id              String    @id @default(uuid())
  tenantId        String?   @map("tenant_id")
  technicianId    String    @map("technician_id")
  type            String    @default("cp") // cp | rtt | maladie | sans_solde | indispo | autre
  start           DateTime?
  end             DateTime?
  halfStart       Boolean   @default(false) @map("half_start")
  halfEnd         Boolean   @default(false) @map("half_end")
  recurringWeekday Int?     @map("recurring_weekday")
  reason          String?
  status          String    @default("valide") // demande | valide | refuse
  validatedById   String?   @map("validated_by_id")
  createdById     String?   @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([technicianId])
  @@map("absences")
}

// ============================================================================
// EPI & MATÉRIEL
// ============================================================================

model Equipment {
  id           String    @id @default(uuid())
  tenantId     String?   @map("tenant_id")
  companyId    String?   @map("company_id")
  category     String    @default("epi") // epi | electroportatif | instrument | vehicule | autre
  name         String
  brand        String?
  model        String?
  serialNumber String?   @map("serial_number")
  size         String?
  purchaseDate DateTime? @map("purchase_date")
  expiryDate   DateTime? @map("expiry_date")
  nextCheckDate DateTime? @map("next_check_date")
  status       String    @default("disponible") // disponible | attribue | maintenance | reforme
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")

  assignments EquipmentAssignment[]
  checks      EquipmentCheck[]

  @@index([tenantId])
  @@map("equipments")
}

model EquipmentAssignment {
  id            String    @id @default(uuid())
  tenantId      String?   @map("tenant_id")
  equipmentId   String    @map("equipment_id")
  technicianId  String    @map("technician_id")
  assignedAt    DateTime  @default(now()) @map("assigned_at")
  returnedAt    DateTime? @map("returned_at")
  conditionNote String?   @map("condition_note")
  createdById   String?   @map("created_by_id")

  equipment  Equipment  @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([equipmentId])
  @@map("equipment_assignments")
}

model EquipmentCheck {
  id          String   @id @default(uuid())
  tenantId    String?  @map("tenant_id")
  equipmentId String   @map("equipment_id")
  date        DateTime
  result      String   @default("conforme") // conforme | non_conforme | a_surveiller
  checkedBy   String?  @map("checked_by")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([equipmentId])
  @@map("equipment_checks")
}

// Pack/kit réutilisable : recette de catégories × quantités. À la dotation, le
// système pioche des équipements DISPONIBLES de chaque catégorie pour le technicien.
model EquipmentPack {
  id        String   @id @default(uuid())
  tenantId  String?  @map("tenant_id")
  name      String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  lines EquipmentPackLine[]

  @@index([tenantId])
  @@map("equipment_packs")
}

model EquipmentPackLine {
  id       String @id @default(uuid())
  tenantId String? @map("tenant_id")
  packId   String @map("pack_id")
  category String @default("outillage")
  quantity Int    @default(1)

  pack EquipmentPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([packId])
  @@map("equipment_pack_lines")
}

// Connexion Odoo (BÉTA) : 1 par tenant. Synchronise le planning (Booking) avec
// les tâches Odoo (project.task) via l'API JSON-RPC. La clé API est CHIFFRÉE.
model OdooConnection {
  id             String    @id @default(uuid())
  tenantId       String?   @map("tenant_id")
  url            String // https://xxx.odoo.com
  db             String
  login          String
  apiKeyEnc      String    @map("api_key_enc") // chiffré AES-256-GCM
  model          String    @default("project.task")
  defaultProject String?   @map("default_project") // nom du projet Odoo cible (push)
  enabled        Boolean   @default(false)
  lastSyncAt     DateTime? @map("last_sync_at")
  lastStatus     String?   @map("last_status")
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("odoo_connections")
}

// ============================================================================
// DUERP — évaluation des risques
// ============================================================================

model RiskUnit {
  id          String   @id @default(uuid())
  tenantId    String?  @map("tenant_id")
  name        String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  items RiskItem[]

  @@index([tenantId])
  @@map("risk_units")
}

model RiskItem {
  id               String    @id @default(uuid())
  tenantId         String?   @map("tenant_id")
  riskUnitId       String    @map("risk_unit_id")
  danger           String
  exposure         String?
  gravity          Int       @default(2) // 1-4
  probability      Int       @default(2) // 1-4
  existingMeasures String?   @map("existing_measures")
  plannedMeasures  String?   @map("planned_measures")
  dueDate          DateTime? @map("due_date")
  responsible      String?
  status           String    @default("a_traiter") // a_traiter | en_cours | maitrise
  createdAt        DateTime  @default(now()) @map("created_at")

  riskUnit RiskUnit @relation(fields: [riskUnitId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([riskUnitId])
  @@map("risk_items")
}

// ============================================================================
// SÉCURITÉ — consignes & accusés de réception
// ============================================================================

model SafetyNotice {
  id          String   @id @default(uuid())
  tenantId    String?  @map("tenant_id")
  title       String
  content     String?
  publishedAt DateTime @default(now()) @map("published_at")
  createdAt   DateTime @default(now()) @map("created_at")

  acks SafetyNoticeAck[]

  @@index([tenantId])
  @@map("safety_notices")
}

model SafetyNoticeAck {
  id           String    @id @default(uuid())
  tenantId     String?   @map("tenant_id")
  noticeId     String    @map("notice_id")
  technicianId String    @map("technician_id")
  ackAt        DateTime? @map("ack_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  notice     SafetyNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  technician Technician   @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([noticeId])
  @@map("safety_notice_acks")
}

// ============================================================================
// COMPÉTENCES — campagnes d'évaluation
// ============================================================================

model SkillCampaign {
  id          String   @id @default(uuid())
  tenantId    String?  @map("tenant_id")
  name        String
  status      String   @default("ouverte") // ouverte | cloturee
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  assessments SkillSelfAssessment[]

  @@index([tenantId])
  @@map("skill_campaigns")
}

model SkillSelfAssessment {
  id             String   @id @default(uuid())
  tenantId       String?  @map("tenant_id")
  campaignId     String   @map("campaign_id")
  technicianId   String   @map("technician_id")
  skillId        String   @map("skill_id")
  proposedLevel  Int      @map("proposed_level")
  comment        String?
  status         String   @default("propose") // propose | valide | ajuste | refuse
  validatedLevel Int?     @map("validated_level")
  validatedById  String?  @map("validated_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  campaign   SkillCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  technician Technician    @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([campaignId])
  @@map("skill_self_assessments")
}

// ============================================================================
// RH — entretiens annuels
// ============================================================================

model InterviewTemplate {
  id        String   @id @default(uuid())
  tenantId  String?  @map("tenant_id")
  name      String
  sections  String   @default("[]") // JSON : [{title, questions:[...]}]
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("interview_templates")
}

model Interview {
  id            String    @id @default(uuid())
  tenantId      String?   @map("tenant_id")
  technicianId  String    @map("technician_id")
  templateId    String?   @map("template_id")
  date          DateTime
  status        String    @default("planifie") // planifie | tenu | signe
  managerNotes  String?   @map("manager_notes")
  employeeNotes String?   @map("employee_notes")
  objectives    String?
  answers       String    @default("{}") // JSON des réponses par question
  createdById   String?   @map("created_by_id")
  signedAt      DateTime? @map("signed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([technicianId])
  @@map("interviews")
}

// ============================================================================
// MARCHÉ PUBLIC — chapitres réutilisables de mémoire technique
// ============================================================================

model TenderMemoSection {
  id        String   @id @default(uuid())
  tenantId  String?  @map("tenant_id")
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("tender_memo_sections")
}

// Historique du cycle de vie d'une affectation : chaque transition de statut
// (proposé -> en cours -> validé / annulé) est tracée avec l'auteur et la date.
// actorName est dénormalisé (instantané) pour rester lisible même si l'auteur
// est renommé ou supprimé.
model TrainingAssignmentEvent {
  id           String   @id @default(uuid())
  assignmentId String   @map("assignment_id")
  status       String // propose | en_cours | valide | annule
  note         String?
  actorId      String?  @map("actor_id")
  actorName    String?  @map("actor_name")
  tenantId     String?  @map("tenant_id")
  createdAt    DateTime @default(now()) @map("created_at")

  assignment TrainingAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  tenant     Tenant?            @relation(fields: [tenantId], references: [id])

  @@index([assignmentId])
  @@index([tenantId])
  @@map("training_assignment_events")
}

// Demande de renfort : un gestionnaire sollicite un technicien d'une AUTRE
// société du tenant (vu anonymisé). Seul l'admin du tenant arbitre.
model AssistanceRequest {
  id                 String    @id @default(uuid())
  tenantId           String?   @map("tenant_id")
  technicianId       String    @map("technician_id")
  requesterUserId    String?   @map("requester_user_id")
  requesterCompanyId String?   @map("requester_company_id")
  message            String
  status             String    @default("pending") // pending | accepted | declined
  adminNote          String?   @map("admin_note")
  resolvedById       String?   @map("resolved_by_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  resolvedAt         DateTime? @map("resolved_at")

  tenant           Tenant?    @relation(fields: [tenantId], references: [id])
  technician       Technician @relation("AssistanceTech", fields: [technicianId], references: [id], onDelete: Cascade)
  requesterCompany Company?   @relation("AssistanceRequester", fields: [requesterCompanyId], references: [id])

  @@index([tenantId])
  @@index([technicianId])
  @@map("assistance_requests")
}

// Webhook sortant : Praxis POST le payload d'un événement vers une URL tierce,
// signé en HMAC-SHA256 (en-tête X-Praxis-Signature) avec `secret`. Cloisonné
// par tenant. `events` = "all" ou liste CSV (ex. "assistance.created").
model Webhook {
  id          String    @id @default(uuid())
  tenantId    String?   @map("tenant_id")
  url         String
  events      String    @default("all")
  secret      String
  isActive    Boolean   @default(true) @map("is_active")
  lastStatus  Int?      @map("last_status")
  lastError   String?   @map("last_error")
  lastFiredAt DateTime? @map("last_fired_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("webhooks")
}
